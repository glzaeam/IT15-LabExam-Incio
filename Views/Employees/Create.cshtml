@model TechCoreSolutions.Models.Employee
@{ ViewData["Title"] = "Add Employee"; }

<div class="mb-4">
    <a asp-action="Index" style="color:#718096;font-size:0.85rem;text-decoration:none;">
        <i class="bi bi-arrow-left"></i> Back to Employees
    </a>
</div>

<div class="tc-card" style="max-width:640px;">
    <div class="tc-card-header">
        <span class="tc-card-title"><i class="bi bi-person-plus"></i> New Employee</span>
    </div>
    <div style="padding:28px;">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="tc-alert tc-alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="tc-form-label">First Name</label>
                    <input asp-for="FirstName" class="tc-form-control" placeholder="e.g. Juan" />
                    <span asp-validation-for="FirstName" style="color:#E53E3E;font-size:0.78rem;"></span>
                </div>
                <div class="col-md-6">
                    <label class="tc-form-label">Last Name</label>
                    <input asp-for="LastName" class="tc-form-control" placeholder="e.g. Dela Cruz" />
                    <span asp-validation-for="LastName" style="color:#E53E3E;font-size:0.78rem;"></span>
                </div>
                <div class="col-md-6">
                    <label class="tc-form-label">Position</label>
                    <input asp-for="Position" class="tc-form-control" placeholder="e.g. Software Engineer" />
                    <span asp-validation-for="Position" style="color:#E53E3E;font-size:0.78rem;"></span>
                </div>
                <div class="col-md-6">
                    <label class="tc-form-label">Department</label>
                    <input asp-for="Department" class="tc-form-control" placeholder="e.g. IT" />
                    <span asp-validation-for="Department" style="color:#E53E3E;font-size:0.78rem;"></span>
                </div>
                <div class="col-md-6">
                    <label class="tc-form-label">Daily Rate (₱)</label>
                    <input asp-for="DailyRate" class="tc-form-control" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="DailyRate" style="color:#E53E3E;font-size:0.78rem;"></span>
                </div>
            </div>
            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn-tc-primary">
                    <i class="bi bi-check-lg"></i> Save Employee
                </button>
                <a asp-action="Index" class="btn-tc-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}