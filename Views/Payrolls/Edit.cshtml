@model TechCoreSolutions.Models.Payroll
@{ ViewData["Title"] = "Edit Payroll"; }

<!-- Edit Payroll Modal -->
<div id="editPayrollModal" style="display: flex; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div style="background: white; border-radius: 16px; padding: 32px; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h2 style="font-size: 1.5rem; font-weight: 700; color: #0D1B2A; margin: 0;">
                <i class="bi bi-pencil-square"></i> Edit Payroll
            </h2>
            <a href="@Url.Action("Index", new { employeeId = Model.EmployeeID })" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #718096; text-decoration: none;">
                <i class="bi bi-x"></i>
            </a>
        </div>

        <form asp-action="Edit" method="post" style="display: grid; grid-template-columns: 1fr; gap: 16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PayrollID" />
            <div asp-validation-summary="ModelOnly" style="color: #E53E3E; font-size: 0.9rem;"></div>
            
            <div>
                <label style="display: block; font-size: 0.75rem; font-weight: 600; color: #718096; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Employee</label>
                <select asp-for="EmployeeID" style="width: 100%; padding: 10px 12px; border: 1px solid #E8E6E0; border-radius: 8px; font-size: 0.875rem; outline: none; font-family: 'DM Sans', sans-serif;" onchange="computePayroll()">
                    @foreach (var e in (IEnumerable<TechCoreSolutions.Models.Employee>)ViewBag.EmployeeList)
                    {
                        <option value="@e.EmployeeID" data-rate="@e.DailyRate"
                            selected="@(e.EmployeeID == Model.EmployeeID ? "selected" : null)">
                            @e.FirstName @e.LastName — ₱@e.DailyRate.ToString("N2")/day
                        </option>
                    }
                </select>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div>
                    <label style="display: block; font-size: 0.75rem; font-weight: 600; color: #718096; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Payroll Date</label>
                    <input asp-for="Date" type="date" style="width: 100%; padding: 10px 12px; border: 1px solid #E8E6E0; border-radius: 8px; font-size: 0.875rem; outline: none; font-family: 'DM Sans', sans-serif;" />
                </div>
                <div>
                    <label style="display: block; font-size: 0.75rem; font-weight: 600; color: #718096; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Days Worked</label>
                    <input asp-for="DaysWorked" type="number" min="0" max="31" id="daysWorked" oninput="computePayroll()" style="width: 100%; padding: 10px 12px; border: 1px solid #E8E6E0; border-radius: 8px; font-size: 0.875rem; outline: none; font-family: 'DM Sans', sans-serif;" />
                    <span asp-validation-for="DaysWorked" style="color:#E53E3E;font-size:0.78rem;"></span>
                </div>
                <div>
                    <label style="display: block; font-size: 0.75rem; font-weight: 600; color: #718096; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Deduction (₱)</label>
                    <input asp-for="Deduction" type="number" step="0.01" min="0" id="deduction" oninput="computePayroll()" style="width: 100%; padding: 10px 12px; border: 1px solid #E8E6E0; border-radius: 8px; font-size: 0.875rem; outline: none; font-family: 'DM Sans', sans-serif;" />
                    <span asp-validation-for="Deduction" style="color:#E53E3E;font-size:0.78rem;"></span>
                </div>
            </div>

            <div id="payPreview" style="margin-top:20px;background:#F4F7FB;border-radius:10px;padding:18px;">
                <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#718096;margin-bottom:12px;">
                    Current Computation
                </div>
                <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                    <div>
                        <div style="font-size:0.75rem;color:#718096;">Gross Pay</div>
                        <div id="previewGross" style="font-size:1.1rem;font-weight:700;color:#0D1B2A;">
                            ₱@Model.GrossPay.ToString("N2")
                        </div>
                    </div>
                    <div style="align-self:center;color:#ccc;font-size:1.2rem;">−</div>
                    <div>
                        <div style="font-size:0.75rem;color:#718096;">Deduction</div>
                        <div id="previewDeduct" style="font-size:1.1rem;font-weight:700;color:#E53E3E;">
                            ₱@Model.Deduction.ToString("N2")
                        </div>
                    </div>
                    <div style="align-self:center;color:#ccc;font-size:1.2rem;">=</div>
                    <div>
                        <div style="font-size:0.75rem;color:#718096;">Net Pay</div>
                        <div id="previewNet" style="font-size:1.3rem;font-weight:800;color:#00896F;">
                            ₱@Model.NetPay.ToString("N2")
                        </div>
                    </div>
                </div>
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 16px;">
                <a asp-action="Index" asp-route-employeeId="@Model.EmployeeID" style="background: white; color: #6B6760; padding: 10px 20px; border: 1px solid #E8E6E0; border-radius: 9px; font-size: 0.875rem; font-weight: 500; cursor: pointer; text-decoration: none; font-family: 'DM Sans', sans-serif;">
                    Cancel
                </a>
                <button type="submit" style="background: #3B82F6; color: white; padding: 10px 20px; border: none; border-radius: 9px; font-size: 0.875rem; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 6px; font-family: 'DM Sans', sans-serif;">
                    <i class="bi bi-check-lg"></i> Update Payroll
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function computePayroll() {
    const sel = document.querySelector('[name="EmployeeID"]');
    const opt = sel?.options[sel.selectedIndex];
    const rate = parseFloat(opt?.dataset?.rate || 0);
    const days = parseFloat(document.getElementById('daysWorked')?.value || 0);
    const deduct = parseFloat(document.getElementById('deduction')?.value || 0);
    const gross = rate * days;
    const net = gross - deduct;
    const fmt = v => '₱' + v.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    document.getElementById('previewGross').textContent = fmt(gross);
    document.getElementById('previewDeduct').textContent = fmt(deduct);
    document.getElementById('previewNet').textContent = fmt(net);
    document.getElementById('previewNet').style.color = net < 0 ? '#E53E3E' : '#00896F';
}
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}