<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechCore Solutions</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Playfair+Display:wght@500;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --white: #ffffff;
            --bg: #ffffff;
            --surface: #ffffff;
            --border: #E8E6E0;
            --border-soft: #EEECE7;
            --text: #1A1917;
            --text-muted: #6B6760;
            --text-hint: #A09D97;
            --accent: #1A1917;
            --accent-green: #2D6A4F;
            --accent-green-light: #EAF4EE;
            --accent-red-light: #FDF0EF;
            --accent-red: #C0392B;
            --sidebar-w: 260px;
            --topbar-h: 60px;

            /* Card shadows — layered for depth */
            --shadow-card: 0 1px 3px rgba(26,25,23,0.06), 0 4px 16px rgba(26,25,23,0.07);
            --shadow-card-hover: 0 2px 6px rgba(26,25,23,0.07), 0 8px 28px rgba(26,25,23,0.10);
            --shadow-sm: 0 1px 2px rgba(26,25,23,0.05), 0 2px 8px rgba(26,25,23,0.06);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 14px;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-w); height: 100vh;
            background: var(--white);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            z-index: 100;
            box-shadow: 2px 0 16px rgba(26,25,23,0.05);
        }

        .sidebar-brand {
            padding: 28px 28px 24px;
            border-bottom: 1px solid var(--border-soft);
        }

        .brand-logo {
            display: flex; align-items: center; gap: 10px;
            margin-bottom: 4px;
        }

        .brand-dot {
            width: 28px; height: 28px;
            background: var(--text);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 2px 8px rgba(26,25,23,0.18);
        }

        .brand-dot span {
            color: white; font-size: 13px; font-weight: 600; letter-spacing: -0.5px;
        }

        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem; font-weight: 600;
            color: var(--text); letter-spacing: -0.3px;
        }

        .brand-sub {
            font-size: 0.7rem; color: var(--text-hint);
            letter-spacing: 0.1em; text-transform: uppercase;
            font-weight: 500; padding-left: 38px;
        }

        .sidebar-section-label {
            font-size: 0.65rem; font-weight: 600;
            color: var(--text-hint);
            letter-spacing: 0.12em; text-transform: uppercase;
            padding: 20px 28px 8px;
        }

        .sidebar-nav { flex: 1; padding-top: 8px; }

        .nav-item {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 28px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.875rem; font-weight: 450;
            transition: all 0.15s ease;
            border-left: 2px solid transparent;
            position: relative;
        }

        .nav-item:hover {
            color: var(--text);
            background: var(--bg);
        }

        .nav-item.active {
            color: var(--text);
            background: var(--bg);
            border-left-color: var(--text);
            font-weight: 500;
        }

        .nav-item i {
            font-size: 15px; width: 18px;
            text-align: center; opacity: 0.7;
        }

        .nav-item.active i { opacity: 1; }

        .sidebar-footer {
            padding: 20px 28px;
            border-top: 1px solid var(--border-soft);
            font-size: 0.7rem; color: var(--text-hint);
            letter-spacing: 0.02em;
        }

        /* ── MAIN ── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
        }

        .topbar {
            height: var(--topbar-h);
            background: var(--white);
            border-bottom: 1px solid var(--border);
            padding: 0 36px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 50;
            box-shadow: 0 1px 8px rgba(26,25,23,0.05);
        }

        .topbar-left {
            display: flex; align-items: center; gap: 8px;
        }

        .topbar-breadcrumb {
            font-size: 0.8rem; color: var(--text-hint);
        }

        .topbar-sep { color: var(--text-hint); font-size: 0.8rem; }

        .topbar-page {
            font-size: 0.875rem; font-weight: 500; color: var(--text);
        }

        .topbar-right {
            display: flex; align-items: center; gap: 8px;
        }

        .status-pill {
            display: inline-flex; align-items: center; gap: 6px;
            background: var(--bg); border: 1px solid var(--border);
            border-radius: 100px;
            padding: 5px 12px;
            font-size: 0.72rem; font-weight: 500;
            color: var(--text-muted); letter-spacing: 0.02em;
        }

        .status-dot {
            width: 6px; height: 6px;
            background: var(--accent-green);
            border-radius: 50%;
        }

        .page-content { padding: 36px 40px; }

        /* ── ALERTS ── */
        .tc-alert {
            display: flex; align-items: center; gap: 10px;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 0.85rem; font-weight: 450;
            margin-bottom: 24px;
            border: 1px solid;
        }

        .tc-alert-success {
            background: var(--accent-green-light);
            border-color: #B7DEC8;
            color: var(--accent-green);
        }

        .tc-alert-danger {
            background: var(--accent-red-light);
            border-color: #F5C6C2;
            color: var(--accent-red);
        }

        /* ── CARDS ── */
        .tc-card {
            background: var(--white);
            border: 1px solid rgba(26,25,23,0.08);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: var(--shadow-card);
            transition: box-shadow 0.2s ease;
        }

        .tc-card:hover {
            box-shadow: var(--shadow-card-hover);
        }

        .tc-card-header {
            padding: 20px 26px;
            border-bottom: 1px solid var(--border-soft);
            display: flex; align-items: center; justify-content: space-between;
            background: var(--white);
        }

        .tc-card-title {
            font-size: 0.9rem; font-weight: 600;
            color: var(--text);
            display: flex; align-items: center; gap: 8px;
        }

        .tc-card-title i { color: var(--text-muted); font-size: 14px; }

        /* ── STAT CARDS (for dashboard metrics) ── */
        .tc-stat-card {
            background: var(--white);
            border: 1px solid rgba(26,25,23,0.07);
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: var(--shadow-sm);
            transition: box-shadow 0.2s ease, transform 0.15s ease;
        }

        .tc-stat-card:hover {
            box-shadow: var(--shadow-card);
            transform: translateY(-1px);
        }

        .tc-stat-label {
            font-size: 0.7rem; font-weight: 600;
            letter-spacing: 0.09em; text-transform: uppercase;
            color: var(--text-hint); margin-bottom: 8px;
        }

        .tc-stat-value {
            font-family: 'Playfair Display', serif;
            font-size: 1.75rem; font-weight: 500;
            color: var(--text); line-height: 1.1;
        }

        .tc-stat-sub {
            font-size: 0.75rem; color: var(--text-hint);
            margin-top: 4px;
        }

        /* ── TABLE ── */
        .tc-table { width: 100%; border-collapse: collapse; }

        .tc-table thead th {
            padding: 12px 22px;
            font-size: 0.68rem; font-weight: 600;
            letter-spacing: 0.1em; text-transform: uppercase;
            color: var(--text-hint);
            border-bottom: 1px solid var(--border-soft);
            text-align: left;
            background: #FAFAF8;
        }

        .tc-table tbody tr {
            border-bottom: 1px solid var(--border-soft);
            transition: background 0.12s;
        }

        .tc-table tbody tr:hover { background: #FAFAF8; }
        .tc-table tbody tr:last-child { border-bottom: none; }
        .tc-table td { padding: 15px 22px; font-size: 0.875rem; }

        /* ── BUTTONS ── */
        .btn-tc-primary {
            display: inline-flex; align-items: center; gap: 6px;
            background: var(--text); color: var(--white);
            border: none; border-radius: 9px;
            padding: 9px 18px;
            font-size: 0.8rem; font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none; cursor: pointer;
            transition: opacity 0.15s, box-shadow 0.15s;
            letter-spacing: 0.01em;
            box-shadow: 0 1px 3px rgba(26,25,23,0.2), 0 2px 8px rgba(26,25,23,0.12);
        }

        .btn-tc-primary:hover {
            opacity: 0.85;
            color: var(--white);
            box-shadow: 0 2px 6px rgba(26,25,23,0.22), 0 4px 14px rgba(26,25,23,0.15);
        }

        .btn-tc-outline {
            display: inline-flex; align-items: center; gap: 6px;
            background: var(--white); color: var(--text-muted);
            border: 1px solid var(--border); border-radius: 9px;
            padding: 7px 14px;
            font-size: 0.8rem; font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none; cursor: pointer;
            transition: all 0.15s;
            box-shadow: 0 1px 2px rgba(26,25,23,0.04);
        }

        .btn-tc-outline:hover {
            background: var(--bg);
            color: var(--text);
            border-color: #C8C6C0;
            box-shadow: 0 1px 4px rgba(26,25,23,0.08);
        }

        .btn-tc-danger {
            display: inline-flex; align-items: center; gap: 6px;
            background: var(--white); color: var(--accent-red);
            border: 1px solid #F5C6C2; border-radius: 9px;
            padding: 7px 14px;
            font-size: 0.8rem; font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none; cursor: pointer;
            transition: all 0.15s;
            box-shadow: 0 1px 2px rgba(26,25,23,0.04);
        }

        .btn-tc-danger:hover {
            background: var(--accent-red-light);
            color: var(--accent-red);
            box-shadow: 0 1px 4px rgba(192,57,43,0.1);
        }

        .btn-icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 32px; height: 32px;
            border-radius: 8px; border: 1px solid var(--border);
            background: var(--white); cursor: pointer;
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.15s;
            font-size: 13px;
            box-shadow: 0 1px 2px rgba(26,25,23,0.04);
        }

        .btn-icon:hover {
            background: var(--bg);
            color: var(--text);
            box-shadow: 0 1px 4px rgba(26,25,23,0.08);
        }

        .btn-icon-danger {
            border-color: #F5C6C2; color: #E57368;
        }

        .btn-icon-danger:hover {
            background: var(--accent-red-light); color: var(--accent-red);
        }

        /* ── FORM ELEMENTS ── */
        .tc-form-group { margin-bottom: 20px; }

        .tc-label {
            display: block;
            font-size: 0.75rem; font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.05em; text-transform: uppercase;
            margin-bottom: 7px;
        }

        .tc-input {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: 9px;
            padding: 10px 14px;
            font-size: 0.875rem;
            font-family: 'DM Sans', sans-serif;
            color: var(--text);
            background: var(--white);
            outline: none;
            transition: border-color 0.15s, box-shadow 0.15s;
            box-shadow: 0 1px 2px rgba(26,25,23,0.04);
        }

        .tc-input:focus {
            border-color: #ABAAA6;
            box-shadow: 0 0 0 3px rgba(26,25,23,0.06), 0 1px 2px rgba(26,25,23,0.04);
        }

        /* ── BADGES ── */
        .badge-dept {
            display: inline-block;
            background: #F0EEE9; color: var(--text-muted);
            border-radius: 6px; padding: 3px 10px;
            font-size: 0.72rem; font-weight: 500;
            letter-spacing: 0.01em;
        }

        .badge-pay {
            display: inline-block;
            background: var(--accent-green-light); color: var(--accent-green);
            border-radius: 6px; padding: 3px 10px;
            font-size: 0.72rem; font-weight: 600;
        }

        /* ── EMPTY STATE ── */
        .empty-state {
            text-align: center; padding: 64px 24px;
            color: var(--text-hint);
        }

        .empty-state i { font-size: 2rem; display: block; margin-bottom: 10px; opacity: 0.4; }
        .empty-state p { font-size: 0.875rem; }

        /* ── PAGE HEADER ── */
        .page-header {
            display: flex; align-items: flex-end; justify-content: space-between;
            margin-bottom: 28px;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.65rem; font-weight: 500;
            color: var(--text); letter-spacing: -0.5px;
            line-height: 1.2;
        }

        .page-subtitle {
            font-size: 0.8rem; color: var(--text-hint);
            margin-top: 4px; font-weight: 400;
        }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-logo">
            <div class="brand-dot"><span>TC</span></div>
            <span class="brand-name">TechCore</span>
        </div>
        <div class="brand-sub">Solutions HR Portal</div>
    </div>

    <nav class="sidebar-nav">
        <div class="sidebar-section-label">Workspace</div>
        <a href="/Employees" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employees" ? "active" : "")">
            <i class="bi bi-people"></i> Employees
        </a>
        <a href="/Payrolls" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payrolls" ? "active" : "")">
            <i class="bi bi-receipt"></i> Payroll
        </a>
    </nav>

    <div class="sidebar-footer">© @DateTime.Now.Year TechCore Solutions</div>
</aside>

<div class="main-wrap">
    <header class="topbar">
        <div class="topbar-left">
            <span class="topbar-breadcrumb">TechCore</span>
            <span class="topbar-sep">/</span>
            <span class="topbar-page">@ViewData["Title"]</span>
        </div>
        <div class="topbar-right">
            <span class="status-pill">
                <span class="status-dot"></span>
                System Online
            </span>
        </div>
    </header>

    <main class="page-content">
        @if (TempData["Success"] != null)
        {
            <div class="tc-alert tc-alert-success">
                <i class="bi bi-check-circle"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="tc-alert tc-alert-danger">
                <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>