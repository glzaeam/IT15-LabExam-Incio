<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechCore Solutions</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --tc-navy: #0D1B2A;
            --tc-blue: #1A56DB;
            --tc-accent: #00C9A7;
            --tc-light: #F4F7FB;
            --tc-border: #E2E8F0;
            --tc-text: #2D3748;
            --tc-muted: #718096;
            --tc-card: #FFFFFF;
            --sidebar-w: 240px;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--tc-light);
            color: var(--tc-text);
            margin: 0;
        }
        .sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-w); height: 100vh;
            background: var(--tc-navy);
            display: flex; flex-direction: column;
            z-index: 100;
        }
        .sidebar-brand {
            padding: 28px 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }
        .sidebar-brand .brand-name {
            font-family: 'Syne', sans-serif;
            font-size: 1.15rem; font-weight: 800;
            color: #fff; display: block; line-height: 1.2;
        }
        .sidebar-brand .brand-sub {
            font-size: 0.7rem; color: var(--tc-accent);
            letter-spacing: 0.12em; text-transform: uppercase;
            font-weight: 500;
        }
        .sidebar-dot {
            display: inline-block; width: 8px; height: 8px;
            background: var(--tc-accent); border-radius: 50%;
            margin-right: 8px; vertical-align: middle;
        }
        .sidebar-nav { padding: 20px 0; flex: 1; }
        .nav-label {
            font-size: 0.65rem; font-weight: 600;
            color: rgba(255,255,255,0.3);
            letter-spacing: 0.12em; text-transform: uppercase;
            padding: 0 24px 10px;
        }
        .sidebar-link {
            display: flex; align-items: center; gap: 12px;
            padding: 11px 24px;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 0.88rem; font-weight: 500;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }
        .sidebar-link:hover, .sidebar-link.active {
            color: #fff;
            background: rgba(255,255,255,0.06);
            border-left-color: var(--tc-accent);
        }
        .sidebar-link i { font-size: 1.05rem; width: 20px; text-align: center; }
        .sidebar-footer {
            padding: 18px 24px;
            border-top: 1px solid rgba(255,255,255,0.07);
            font-size: 0.72rem; color: rgba(255,255,255,0.3);
        }
        .main-wrap {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex; flex-direction: column;
        }
        .topbar {
            background: #fff;
            border-bottom: 1px solid var(--tc-border);
            padding: 14px 32px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 50;
        }
        .topbar-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.1rem; font-weight: 700; color: var(--tc-navy);
        }
        .topbar-badge {
            background: var(--tc-accent); color: #fff;
            font-size: 0.7rem; padding: 3px 10px;
            border-radius: 20px; font-weight: 600;
        }
        .page-content { padding: 32px; flex: 1; }
        .tc-card {
            background: var(--tc-card);
            border: 1px solid var(--tc-border);
            border-radius: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
            overflow: hidden;
        }
        .tc-card-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--tc-border);
            display: flex; align-items: center; justify-content: space-between;
            background: #fff;
        }
        .tc-card-title {
            font-family: 'Syne', sans-serif;
            font-size: 0.95rem; font-weight: 700; color: var(--tc-navy);
            display: flex; align-items: center; gap: 8px;
        }
        .tc-card-title i { color: var(--tc-blue); }
        .tc-table { width: 100%; border-collapse: collapse; }
        .tc-table thead th {
            background: var(--tc-light); padding: 11px 16px;
            font-size: 0.72rem; font-weight: 600;
            letter-spacing: 0.08em; text-transform: uppercase;
            color: var(--tc-muted); border-bottom: 1px solid var(--tc-border);
        }
        .tc-table tbody tr {
            border-bottom: 1px solid var(--tc-border);
            transition: background 0.15s;
        }
        .tc-table tbody tr:hover { background: #F8FAFF; }
        .tc-table tbody tr:last-child { border-bottom: none; }
        .tc-table td { padding: 13px 16px; font-size: 0.875rem; }
        .btn-tc-primary {
            background: var(--tc-blue); color: #fff; border: none;
            padding: 8px 18px; border-radius: 8px;
            font-size: 0.83rem; font-weight: 600;
            text-decoration: none; display: inline-flex;
            align-items: center; gap: 6px; transition: background 0.2s;
            cursor: pointer;
        }
        .btn-tc-primary:hover { background: #1447C0; color: #fff; }
        .btn-tc-outline {
            background: transparent; color: var(--tc-blue);
            border: 1.5px solid var(--tc-blue);
            padding: 6px 14px; border-radius: 7px;
            font-size: 0.8rem; font-weight: 600;
            text-decoration: none; display: inline-flex;
            align-items: center; gap: 5px; transition: all 0.2s;
        }
        .btn-tc-outline:hover { background: var(--tc-blue); color: #fff; }
        .btn-tc-danger {
            background: transparent; color: #E53E3E;
            border: 1.5px solid #E53E3E;
            padding: 6px 14px; border-radius: 7px;
            font-size: 0.8rem; font-weight: 600;
            text-decoration: none; display: inline-flex;
            align-items: center; gap: 5px; transition: all 0.2s;
        }
        .btn-tc-danger:hover { background: #E53E3E; color: #fff; }
        .tc-form-label {
            font-size: 0.8rem; font-weight: 600; color: var(--tc-muted);
            letter-spacing: 0.04em; text-transform: uppercase;
            margin-bottom: 6px; display: block;
        }
        .tc-form-control {
            width: 100%; border: 1.5px solid var(--tc-border);
            border-radius: 8px; padding: 10px 14px;
            font-size: 0.88rem; color: var(--tc-text);
            font-family: 'DM Sans', sans-serif;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: #fff; outline: none;
        }
        .tc-form-control:focus {
            border-color: var(--tc-blue);
            box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
        }
        .tc-alert {
            padding: 12px 18px; border-radius: 8px;
            font-size: 0.85rem; font-weight: 500;
            display: flex; align-items: center; gap: 10px;
            margin-bottom: 20px;
        }
        .tc-alert-success {
            background: #F0FFF9; border: 1px solid #9AE6B4; color: #276749;
        }
        .tc-alert-danger {
            background: #FFF5F5; border: 1px solid #FEB2B2; color: #9B2C2C;
        }
        .dept-badge {
            display: inline-block; background: rgba(26,86,219,0.08);
            color: var(--tc-blue); border-radius: 20px;
            padding: 3px 12px; font-size: 0.75rem; font-weight: 600;
        }
        .pay-badge {
            display: inline-block; background: rgba(0,201,167,0.1);
            color: #00896F; border-radius: 20px;
            padding: 3px 12px; font-size: 0.75rem; font-weight: 600;
        }
        .empty-state {
            text-align: center; padding: 56px 24px; color: var(--tc-muted);
        }
        .empty-state i { font-size: 2.8rem; opacity: 0.3; display: block; margin-bottom: 12px; }
        .empty-state p { font-size: 0.9rem; margin: 0; }
    </style>
</head>
<body>
<div class="sidebar">
    <div class="sidebar-brand">
        <span class="brand-name"><span class="sidebar-dot"></span>TechCore</span>
        <span class="brand-sub">Solutions HR Portal</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-label">Main Menu</div>
        <a href="/Employees" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employees" ? "active" : "")">
            <i class="bi bi-people-fill"></i> Employees
        </a>
        <a href="/Payrolls" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payrolls" ? "active" : "")">
            <i class="bi bi-cash-stack"></i> Payroll
        </a>
    </nav>
    <div class="sidebar-footer">&copy; @DateTime.Now.Year TechCore Solutions</div>
</div>

<div class="main-wrap">
    <div class="topbar">
        <span class="topbar-title">@ViewData["Title"]</span>
        <span class="topbar-badge"><i class="bi bi-shield-check"></i> HR Portal</span>
    </div>
    <div class="page-content">
        @if (TempData["Success"] != null)
        {
            <div class="tc-alert tc-alert-success">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>